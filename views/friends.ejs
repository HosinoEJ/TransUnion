<!DOCTYPE html>
<html lang="zh_tw"><!--這裏的lang可以控制字體的，相對來説重要一些-->
    <%- include('partials/head') %>
    <head>
        <style>
            body { font-family: 'PingFang TC', 'Microsoft JhengHei', sans-serif; background: #f9fafb; color: #374151; line-height: 1.6; }
            .container { max-width: 900px; margin: 0 auto;}
            .header { text-align: center; margin-bottom: 40px; }
            
            /* 網格佈局 */
            .links-grid { 
                display: grid; 
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); 
                gap: 20px; 
            }

            /* 卡片樣式 */
            .link-card {
                padding: 20px;
                text-decoration: none;
                transition: transform 0.2s, box-shadow 0.2s;
                display: flex;
                align-items: center;
            }
            .link-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            }

            .info h3 { margin: 0; font-size: 1.1rem; color: #111827; }
            .info p { margin: 5px 0 0; font-size: 0.85rem; color: #6b7280; }

            /* 申請說明區塊 */
            .apply-section {
                margin-top: 50px;
                padding: 30px;
                border-radius: 12px;
            }
        </style>
    </head>
    <body><!--class="center_PG"的意思是讓這個頁面居中對齊，否則自己用display設定版面（可選）-->
        
            <%- include('partials/MTF') %>
            <main class="main">
                <%- include('partials/header') %>
                <div class="container">
                    <div class="header">
                        <h1>FRIENDS</h1>
                        <p></p>
                    </div>
                    <div class="links-grid">
                        
                            <% friends.forEach(friend => { %>
                                <a href="<%= friend.url %>" target="_blank" class="link-card friend-card DivStyle-Glass">
                                    <img src="<%= friend.avatar %>" style="width: 60px; height: 60px; border-radius: 50%; margin-right: 15px; border: 2px solid <%= friend.color %>;">
                                    <div class="info">
                                        <h3 id="<%= friend.color %>" style="margin: 0; font-size: 1.1rem;"><%= friend.name %></h3>
                                        <p style="margin: 5px 0 0; font-size: 0.85rem; opacity: 0.7;"><%= friend.desc %></p>
                                    </div>
                                </a>
                            <% }); %>
                    </div>
                </div>
            </main>
            <%- include('partials/footer') %>
        <%- include('partials/footer_JS') %>
    </body>
</html>